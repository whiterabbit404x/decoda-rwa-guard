APP_MODE=local
SQLITE_PATH=.data/phase1.db
REDIS_ENABLED=false
# REDIS_URL is required in production (APP_ENV=production/prod/staging) for distributed rate
# limiting, session token revocation, and SSE alert streaming. Production startup will fail
# if REDIS_URL is missing or if Redis is not reachable at boot time.
# Leave blank for local/dev — in-memory fallback is used automatically (rate_limit_enterprise_ready=false).
REDIS_URL=
# REDIS_TEMPORARILY_DISABLED is REJECTED in production (APP_ENV=production/prod/staging).
# In local/dev only, setting this to 'true' allows running without Redis while showing
# degraded status. Never set this to 'true' in production — startup will fail with a clear error.
REDIS_TEMPORARILY_DISABLED=false

# Live EVM provider (required for live monitoring; leave empty in local dev)
EVM_RPC_URL=
EVM_CHAIN_ID=

# Multiple Base RPC providers with SAFE per-host failover (recommended for prod).
# Comma-separated list, tried in order. If the first provider returns HTTP 429
# (rate limit), ONLY that provider host is benched and the next provider serves the
# poll — the worker keeps polling as long as at least one provider works. When EVERY
# provider is rate-limited the worker backs off (provider_poll_skipped, checked=0).
# Precedence for the global Base/EVM endpoint:
#   1. EVM_RPC_URLS        (this multi-provider list — takes priority)
#   2. STAGING_EVM_RPC_URL
#   3. EVM_RPC_URL
# Per-chain vars (EVM_RPC_URL_<chain_id> / <CHAIN>_EVM_RPC_URL, below) still win for
# their specific chain. Logs and the UI only ever surface the provider HOST — never
# the full URL, path, or API key.
# Example: EVM_RPC_URLS=https://base-mainnet.g.alchemy.com/v2/KEY,https://base.quicknode.example/TOKEN
EVM_RPC_URLS=

# Per-chain RPC routing (multi-chain deployments). A target is routed to the RPC
# that serves the chain it is labeled with (targets.chain_network). Precedence:
#   1. EVM_RPC_URL_<chain_id>   e.g. EVM_RPC_URL_8453 (Base), EVM_RPC_URL_1 (Ethereum)
#   2. <CHAIN>_EVM_RPC_URL      e.g. BASE_EVM_RPC_URL, ETHEREUM_EVM_RPC_URL
#   3. EVM_RPC_URL / STAGING_EVM_RPC_URL global fallback
# The worker probes eth_chainId and FAILS CLOSED (skips, no telemetry) when the
# resolved endpoint does not serve the target's chain — so an Ethereum-labeled
# target is never scanned against a Base RPC. If you only configure a Base RPC,
# non-Base EVM targets are skipped/marked misconfigured rather than mis-reported.
EVM_RPC_URL_1=
EVM_RPC_URL_8453=
# Optional comma-separated per-chain failover endpoints, e.g. EVM_RPC_FAILOVER_URLS_8453=

# RPC pressure / rate-limit tuning. Defaults keep the provider from being
# rate-limited; raise the interval (or lower polling) if the provider quota is small.
#   EVM_POLLING_INTERVAL_SECONDS  worker poll cadence in seconds (default 60).
#                                 Legacy alias: MONITORING_WORKER_INTERVAL_SECONDS.
#   SYSTEM_HEALTH_RPC_TTL_SECONDS /system-health caches the Base RPC probe for this
#                                 many seconds so refreshes don't re-hit the RPC (default 60).
#   SYSTEM_HEALTH_RPC_TIMEOUT_SECONDS  bounded probe timeout for /system-health (default 8).
#   EVM_RPC_TIMEOUT_SECONDS / EVM_RPC_MAX_RETRIES / EVM_RPC_BACKOFF_SECONDS  worker
#                                 per-request timeout, retry count, and exponential backoff
#                                 (defaults 10 / 3 / 1). 429 responses honor Retry-After.
#   MIN_EVM_POLLING_INTERVAL_SECONDS  production floor for per-target poll intervals
#                                 (default 60). Targets configured below this are capped
#                                 so the worker never re-hits eth_blockNumber sub-minute.
#   RPC_PROVIDER_BACKOFF_MIN_SECONDS  minimum PER-PROVIDER-HOST backoff after an HTTP 429
#                                 (default 120; 600 in production). A rate-limited provider
#                                 is benched on its own — other EVM_RPC_URLS providers keep
#                                 serving. Only when EVERY configured provider is benched do
#                                 the worker, coverage probe, probe_rpc_health, and
#                                 /system-health skip RPC. A larger Retry-After extends it.
EVM_POLLING_INTERVAL_SECONDS=60
MIN_EVM_POLLING_INTERVAL_SECONDS=60

# Base (chain_id 8453) scan caps. Base produces ~2s blocks and busy RWA wallets return
# large eth_getLogs responses, so the defaults keep every per-cycle scan and every
# eth_getLogs query small enough that QuickNode does not reject them with HTTP 413. A 413
# is treated as a query-size problem (reduce the window), NOT a provider outage; the cursor
# is never advanced past a block range whose logs were not successfully scanned.
#   BASE_MAX_BLOCKS_PER_CYCLE         max blocks scanned per poll cycle on Base (default 100).
#   BASE_CATCHUP_MAX_BLOCKS_PER_CYCLE max blocks advanced per cycle while catching up a
#                                     backlog (default = BASE_MAX_BLOCKS_PER_CYCLE = 100), so
#                                     a deep backlog catches up gradually, never in one heavy poll.
#   BASE_MAX_LOGS_BLOCK_RANGE         max block span per eth_getLogs request (default 25).
#   BASE_MIN_LOGS_BLOCK_RANGE         adaptive-halving floor after a 413 (default 5). If even
#                                     this span is too large the cycle stops without advancing.
#   BASE_LIVE_TAIL_BLOCKS             recent-block live-tail window scanned during catch-up
#                                     (default 100). Generic override: EVM_LIVE_TAIL_BLOCKS.
BASE_MAX_BLOCKS_PER_CYCLE=100
BASE_CATCHUP_MAX_BLOCKS_PER_CYCLE=100
BASE_MAX_LOGS_BLOCK_RANGE=25
BASE_MIN_LOGS_BLOCK_RANGE=5
BASE_LIVE_TAIL_BLOCKS=100

# Staging live EVM provider evidence (blocker 3).
# STAGING_EVM_RPC_URL is preferred over EVM_RPC_URL in staging proof generation.
# STAGING_EVM_CHAIN_ID is preferred over EVM_CHAIN_ID.
# STAGING_WORKER_ENABLED=true confirms the monitoring worker is active.
# Without these, provider_ready=false and live_evidence_ready=false (fail closed).
STAGING_EVM_RPC_URL=
STAGING_EVM_CHAIN_ID=1
STAGING_WORKER_ENABLED=true

# Billing (Paddle — required for paid launch; leave empty for pilot/no-billing mode)
BILLING_PROVIDER=paddle
PADDLE_ENVIRONMENT=production
PADDLE_API_KEY=
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
# Optional Paddle browser/redirect configuration
PADDLE_CLIENT_TOKEN=
PADDLE_SUCCESS_URL=
PADDLE_CANCEL_URL=
# Legacy Paddle flows only; prefer PADDLE_SELLER_ID when applicable
PADDLE_VENDOR_ID=
PADDLE_SELLER_ID=

# Email (Resend — required for transactional email in production)
EMAIL_PROVIDER=resend
MAIL_PROVIDER=resend
EMAIL_DOMAIN=
EMAIL_FROM=
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Base Real-time Ingestion Worker (realtime-worker process)
# ---------------------------------------------------------------------------
# The 300s polling worker continues to run as backup/backfill regardless of
# these settings. Set BASE_REALTIME_ENABLED=true and BASE_WS_RPC_URL to enable
# near-real-time (sub-30s) alert detection for Base wallet/RWA transfers.
#
# Defaults: disabled (BASE_REALTIME_ENABLED=false). Safe to leave unset in
# local dev; the polling worker handles backfill automatically.
#
BASE_REALTIME_ENABLED=false
BASE_REALTIME_PROVIDER=websocket
# WebSocket RPC URL for Base mainnet (required when BASE_REALTIME_ENABLED=true)
# Only the host is ever logged — never the full URL, path, or API key.
BASE_WS_RPC_URL=
# Webhook mode (alternative to websocket; requires BASE_WEBHOOK_SECRET)
BASE_WEBHOOK_SECRET=
# Confirmations to wait before processing a block (default 1; use 2 for extra safety)
BASE_REALTIME_CONFIRMATIONS=1
# Rate limiter: max events persisted per minute across all monitored wallets.
# Default 1000 is very permissive; lower to protect DB during a high-volume event.
BASE_REALTIME_MAX_EVENTS_PER_MINUTE=1000
# When true (default), the polling worker continues to run as a fallback even
# when the realtime worker is active. Always recommended.
BASE_REALTIME_FALLBACK_TO_POLLING=true
