APP_MODE=local
SQLITE_PATH=.data/phase1.db
REDIS_ENABLED=false
REDIS_URL=
# Temporary single-instance/staging escape hatch only. This keeps startup available but
# readiness remains degraded and enterprise_ready=false until Redis is configured.
REDIS_TEMPORARILY_DISABLED=false

# Live EVM provider (required for live monitoring; leave empty in local dev)
EVM_RPC_URL=
EVM_CHAIN_ID=

# Staging live EVM provider evidence (blocker 3).
# STAGING_EVM_RPC_URL is preferred over EVM_RPC_URL in staging proof generation.
# STAGING_EVM_CHAIN_ID is preferred over EVM_CHAIN_ID.
# STAGING_WORKER_ENABLED=true confirms the monitoring worker is active.
# Without these, provider_ready=false and live_evidence_ready=false (fail closed).
STAGING_EVM_RPC_URL=
STAGING_EVM_CHAIN_ID=1
STAGING_WORKER_ENABLED=true

# Billing (Paddle — required for paid launch; leave empty for pilot/no-billing mode)
BILLING_PROVIDER=paddle
PADDLE_ENVIRONMENT=production
PADDLE_API_KEY=
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
# Optional Paddle browser/redirect configuration
PADDLE_CLIENT_TOKEN=
PADDLE_SUCCESS_URL=
PADDLE_CANCEL_URL=
# Legacy Paddle flows only; prefer PADDLE_SELLER_ID when applicable
PADDLE_VENDOR_ID=
PADDLE_SELLER_ID=

# Email (Resend — required for transactional email in production)
EMAIL_PROVIDER=resend
MAIL_PROVIDER=resend
EMAIL_DOMAIN=
EMAIL_FROM=
RESEND_API_KEY=
