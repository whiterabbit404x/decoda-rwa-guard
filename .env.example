APP_MODE=local
SQLITE_PATH=.data/phase1.db
REDIS_ENABLED=false
# REDIS_URL is required in production (APP_ENV=production/prod/staging) for distributed rate
# limiting, session token revocation, and SSE alert streaming. Production startup will fail
# if REDIS_URL is missing or if Redis is not reachable at boot time.
# Leave blank for local/dev — in-memory fallback is used automatically (rate_limit_enterprise_ready=false).
REDIS_URL=
# REDIS_TEMPORARILY_DISABLED is REJECTED in production (APP_ENV=production/prod/staging).
# In local/dev only, setting this to 'true' allows running without Redis while showing
# degraded status. Never set this to 'true' in production — startup will fail with a clear error.
REDIS_TEMPORARILY_DISABLED=false

# Live EVM provider (required for live monitoring; leave empty in local dev)
EVM_RPC_URL=
EVM_CHAIN_ID=

# Multiple Base RPC providers with SAFE per-host failover (recommended for prod).
# Comma-separated list, tried in order. If the first provider returns HTTP 429
# (rate limit), ONLY that provider host is benched and the next provider serves the
# poll — the worker keeps polling as long as at least one provider works. When EVERY
# provider is rate-limited the worker backs off (provider_poll_skipped, checked=0).
# Precedence for the global Base/EVM endpoint:
#   1. EVM_RPC_URLS        (this multi-provider list — takes priority)
#   2. STAGING_EVM_RPC_URL
#   3. EVM_RPC_URL
# Per-chain vars (EVM_RPC_URL_<chain_id> / <CHAIN>_EVM_RPC_URL, below) still win for
# their specific chain. Logs and the UI only ever surface the provider HOST — never
# the full URL, path, or API key.
# Example: EVM_RPC_URLS=https://base-mainnet.g.alchemy.com/v2/KEY,https://base.quicknode.example/TOKEN
EVM_RPC_URLS=

# Per-chain RPC routing (multi-chain deployments). A target is routed to the RPC
# that serves the chain it is labeled with (targets.chain_network). Precedence:
#   1. EVM_RPC_URL_<chain_id>   e.g. EVM_RPC_URL_8453 (Base), EVM_RPC_URL_1 (Ethereum)
#   2. <CHAIN>_EVM_RPC_URL      e.g. BASE_EVM_RPC_URL, ETHEREUM_EVM_RPC_URL
#   3. EVM_RPC_URL / STAGING_EVM_RPC_URL global fallback
# The worker probes eth_chainId and FAILS CLOSED (skips, no telemetry) when the
# resolved endpoint does not serve the target's chain — so an Ethereum-labeled
# target is never scanned against a Base RPC. If you only configure a Base RPC,
# non-Base EVM targets are skipped/marked misconfigured rather than mis-reported.
EVM_RPC_URL_1=
EVM_RPC_URL_8453=
# Optional comma-separated per-chain failover endpoints, e.g. EVM_RPC_FAILOVER_URLS_8453=

# RPC pressure / rate-limit tuning. Defaults keep the provider from being
# rate-limited; raise the interval (or lower polling) if the provider quota is small.
#   EVM_POLLING_INTERVAL_SECONDS  worker poll cadence in seconds (default 60).
#                                 Legacy alias: MONITORING_WORKER_INTERVAL_SECONDS.
#   SYSTEM_HEALTH_RPC_TTL_SECONDS /system-health caches the Base RPC probe for this
#                                 many seconds so refreshes don't re-hit the RPC (default 60).
#   SYSTEM_HEALTH_RPC_TIMEOUT_SECONDS  bounded probe timeout for /system-health (default 8).
#   EVM_RPC_TIMEOUT_SECONDS / EVM_RPC_MAX_RETRIES / EVM_RPC_BACKOFF_SECONDS  worker
#                                 per-request timeout, retry count, and exponential backoff
#                                 (defaults 10 / 3 / 1). 429 responses honor Retry-After.
#   MIN_EVM_POLLING_INTERVAL_SECONDS  production floor for per-target poll intervals
#                                 (default 60). Targets configured below this are capped
#                                 so the worker never re-hits eth_blockNumber sub-minute.
#   RPC_PROVIDER_BACKOFF_MIN_SECONDS  minimum PER-PROVIDER-HOST backoff after an HTTP 429
#                                 (default 120; 600 in production). A rate-limited provider
#                                 is benched on its own — other EVM_RPC_URLS providers keep
#                                 serving. Only when EVERY configured provider is benched do
#                                 the worker, coverage probe, probe_rpc_health, and
#                                 /system-health skip RPC. A larger Retry-After extends it.
EVM_POLLING_INTERVAL_SECONDS=60
MIN_EVM_POLLING_INTERVAL_SECONDS=60
# MONITORING_STABLE_POLL_STALE_SECONDS  how old the stable RPC polling heartbeat/poll may
#                                 be before it is reported stale (default 900 = 15 min).
#                                 The stable loop runs on a multi-minute cadence, so this is
#                                 deliberately forgiving — a 4–5 minute-old poll at a 5-minute
#                                 cadence is HEALTHY, not stale. Floored at max(2*poll_interval,
#                                 600s); the same threshold drives the top banner, worker-status
#                                 card, limitation text, and runtime summary so they agree.
# MONITORING_STABLE_POLL_STALE_SECONDS=900

# Base (chain_id 8453) scan caps. Base produces ~2s blocks and busy RWA wallets return
# large eth_getLogs responses, so the defaults keep every per-cycle scan and every
# eth_getLogs query small enough that QuickNode does not reject them with HTTP 413. A 413
# is treated as a query-size problem (reduce the window), NOT a provider outage; the cursor
# is never advanced past a block range whose logs were not successfully scanned.
#   BASE_MAX_BLOCKS_PER_CYCLE         max blocks scanned per poll cycle on Base (default 100).
#   BASE_CATCHUP_MAX_BLOCKS_PER_CYCLE max blocks advanced per cycle while catching up a
#                                     backlog (default = BASE_MAX_BLOCKS_PER_CYCLE = 100), so
#                                     a deep backlog catches up gradually, never in one heavy poll.
#   BASE_MAX_LOGS_BLOCK_RANGE         max block span per eth_getLogs request (default 25).
#   BASE_MIN_LOGS_BLOCK_RANGE         adaptive-halving floor after a 413 (default 5). If even
#                                     this span is too large the cycle stops without advancing.
#   BASE_LIVE_TAIL_BLOCKS             recent-block live-tail window scanned during catch-up
#                                     (default 100). Generic override: EVM_LIVE_TAIL_BLOCKS.
BASE_MAX_BLOCKS_PER_CYCLE=100
BASE_CATCHUP_MAX_BLOCKS_PER_CYCLE=100
BASE_MAX_LOGS_BLOCK_RANGE=25
BASE_MIN_LOGS_BLOCK_RANGE=5
BASE_LIVE_TAIL_BLOCKS=100

# Staging live EVM provider evidence (blocker 3).
# STAGING_EVM_RPC_URL is preferred over EVM_RPC_URL in staging proof generation.
# STAGING_EVM_CHAIN_ID is preferred over EVM_CHAIN_ID.
# STAGING_WORKER_ENABLED=true confirms the monitoring worker is active.
# Without these, provider_ready=false and live_evidence_ready=false (fail closed).
STAGING_EVM_RPC_URL=
STAGING_EVM_CHAIN_ID=1
STAGING_WORKER_ENABLED=true

# Billing (Paddle — required for paid launch; leave empty for pilot/no-billing mode)
BILLING_PROVIDER=paddle
PADDLE_ENVIRONMENT=production
PADDLE_API_KEY=
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
# Optional Paddle browser/redirect configuration
PADDLE_CLIENT_TOKEN=
PADDLE_SUCCESS_URL=
PADDLE_CANCEL_URL=
# Legacy Paddle flows only; prefer PADDLE_SELLER_ID when applicable
PADDLE_VENDOR_ID=
PADDLE_SELLER_ID=

# QuickNode Streams webhook signing secret (HMAC-SHA256). Shared by all three
# QuickNode Stream destination routes:
#   POST /api/integrations/quicknode/streams/base           legacy delivery lane
#                                                           (stream_key='base')
#   POST /api/integrations/quicknode/streams/base-live      LIVE chain-tip lane
#                                                           (checkpoint quicknode:base:live,
#                                                            detected_by=quicknode_stream) —
#                                                           point a QuickNode stream that
#                                                           STARTS AT THE LATEST BLOCK here.
#   POST /api/integrations/quicknode/streams/base-backfill  optional historical lane
#                                                           (checkpoint quicknode:base:backfill,
#                                                            detected_by=quicknode_stream_backfill)
# Also gates the read-only ops replay endpoint
# GET /api/integrations/quicknode/streams/base/debug-tx?tx_hash=<hash> — pass the
# same secret as the x-quicknode-ops-token header.
QUICKNODE_STREAMS_SECRET=
# Optional debug tracing for the "QuickNode Stream missed a fresh tx" investigation.
# When set, every QuickNode batch logs quicknode_stream_batch_range (contains_debug_tx)
# and, for the configured tx, quicknode_stream_debug_tx_seen. Comma-separated hashes ok.
QUICKNODE_STREAM_DEBUG_TX_HASH=
# Optional known block number (decimal or 0x-hex) of QUICKNODE_STREAM_DEBUG_TX_HASH.
# Enables quicknode_stream_debug_tx_not_seen: a batch whose range covers this block but
# does not contain the tx proves the block was delivered without the tx (normalizer/filter miss).
QUICKNODE_STREAM_DEBUG_TX_BLOCK=
# Max blocks a single gap-triggered backfill re-fetches from Base RPC when the stream
# skips blocks (jump from block A to B where B > A + 1). Bounds one webhook; the
# checkpoint still advances past the whole gap and stable RPC polling covers any
# remainder. Default 200; 0 disables the cap.
QUICKNODE_STREAM_BACKFILL_MAX_BLOCKS=

# ---------------------------------------------------------------------------
# QuickNode LIVE chain-tip worker (quicknode-live-worker process)
#
# Real-time detection lane. Reads the current Base head every tick and processes
# the small forward window at the tip (detected_by=quicknode_stream), publishing
# each committed row to the workspace :telemetry Redis stream so the Target
# Telemetry page prepends it within a few seconds — independent of the QuickNode
# Streams webhook backlog. A separate lower-priority lane walks missed historical
# blocks. Requires a Base RPC endpoint (EVM_RPC_URL_8453 / BASE_EVM_RPC_URL /
# EVM_RPC_URL) and, for the browser push, REDIS_URL. Multi-replica safe via a
# Postgres advisory lock. Default: disabled — the webhook + stable polling still work.
# ---------------------------------------------------------------------------
# Master switch for the dedicated quicknode-live-worker Railway service (config file
# railway-quicknode-live-worker.json). When true the worker validates its Base RPC
# config and, if valid, emits event=quicknode_live_lane_started and runs the chain-tip
# lane. When false it idles, emitting event=quicknode_live_lane_disabled every minute.
# When true but Base RPC is missing it fails loudly with
# event=quicknode_live_lane_configuration_error (non-zero exit -> Railway restarts it),
# never silently idling.
QUICKNODE_LIVE_ENABLED=false
# Human-readable stream-key LABELS shown in the structured logs + readiness marker
# (distinct from the fixed checkpoint identities quicknode:base:live / :backfill).
# Defaults are the canonical route names; override only to match your dashboard naming.
QUICKNODE_LIVE_STREAM_KEY=base-live
QUICKNODE_BACKFILL_STREAM_KEY=base-backfill
# Whether the lower-priority historical BACKFILL lane runs. Default true; set false to
# suspend historical catch-up without affecting the tip or Stable RPC Polling.
QUICKNODE_BACKFILL_ENABLED=true
# Seconds between live ticks (the tip-following cadence — NOT the stable-poll interval,
# which stays the fallback). Default 3.
QUICKNODE_LIVE_POLL_INTERVAL_SECONDS=3
# Confirmation offset subtracted from the chain head before a block is "safe" to
# process, so a tip reorg cannot persist a transfer that later vanishes. Default 2.
# (QUICKNODE_LIVE_CONFIRMATIONS is still accepted as a legacy alias.)
QUICKNODE_LIVE_CONFIRMATION_BLOCKS=2
# Max blocks the live lane processes per tick (the rest are caught next tick). Default 25.
QUICKNODE_LIVE_MAX_BLOCKS_PER_TICK=25
# Max blocks one historical backfill step processes per tick (lower priority). Default 50.
QUICKNODE_BACKFILL_MAX_BLOCKS_PER_TICK=50
# Lag (chain_head - live_checkpoint) at/below which the lane reports "Live"; above it
# the lane is "Degraded" and Stable RPC Polling is the fallback. Default 10.
# (QUICKNODE_LIVE_LAG_THRESHOLD_BLOCKS is still accepted as a legacy alias.)
QUICKNODE_LIVE_MAX_LAG_BLOCKS=10
# No live-checkpoint advance for longer than this marks the lane "Stale". Default 300.
QUICKNODE_LIVE_STALE_SECONDS=300
# Optional seed block for the lower-priority historical BACKFILL lane. The lane is
# dormant until it has a checkpoint to resume from; set this to the first block of a
# known gap (e.g. the QuickNode Stream's old stream_started_at_block) so it walks the
# missed range the live lane deliberately skips. Idempotent — only seeds when unseeded.
# Unset by default (the live lane covers the tip; stable polling covers the rest).
QUICKNODE_BACKFILL_START_BLOCK=

# ---------------------------------------------------------------------------
# Real-time telemetry SSE heartbeat cadence
# ---------------------------------------------------------------------------
# Seconds between SSE heartbeat comments on /stream/telemetry and /stream/alerts
# (== the Redis xread block interval). Keep inside 15–25s so an idle-timeout proxy
# (Railway edge / Next.js fetch) never drops a quiet-but-healthy stream and forces a
# "Reconnecting…" flap. Clamped to [5, 25]s. Default 15.
SSE_HEARTBEAT_INTERVAL_SECONDS=15

# ---------------------------------------------------------------------------
# AI Evidence & Triage Agent (evidence-grounded incident investigation)
# ---------------------------------------------------------------------------
# Constrained analysis service: it summarizes incidents, builds evidence-linked
# timelines, recommends predefined runbooks, and drafts reports. It NEVER signs
# transactions, moves funds, pauses contracts, freezes wallets, or executes any
# on-chain action — recommendations are human-approved only.
#
# Off by default. Do NOT enable in production until migration 0123 is deployed,
# authorization tests pass, mock + OpenAI staging tests pass, budget controls
# work, the dedicated worker service is healthy, evidence citations are correct,
# and the prohibited-action tests pass. See docs/AI_TRIAGE_OPENAI.md.
AI_TRIAGE_ENABLED=false
# Provider for the concrete implementation. OpenAI is the documented initial
# production provider. Supported: openai, mock. (anthropic is retained but
# optional.) Empty -> offline mock (no network call). Any UNKNOWN value fails
# closed: the triage job lands in a safe failed state (unknown_provider).
AI_PROVIDER=openai
# OpenAI model id for triage (e.g. a current OpenAI Responses-API model).
# Required when AI_PROVIDER=openai — the worker fails closed if it is unset.
AI_MODEL_TRIAGE=
# API key for the selected provider (a Railway secret). Never logged. For OpenAI,
# OPENAI_API_KEY is also read; for Anthropic, ANTHROPIC_API_KEY is also read.
# NEVER commit a real key to source, GitHub, tests, screenshots, or .env.example.
AI_API_KEY=
# Hard request timeout for a single provider call, in seconds.
AI_REQUEST_TIMEOUT_SECONDS=30
# Max input/output tokens per triage call (used for pre-call budget estimation).
AI_MAX_INPUT_TOKENS=12000
AI_MAX_OUTPUT_TOKENS=2000
# Per-incident maximum estimated cost (USD). A triage exceeding this is blocked
# before any provider call (status budget_blocked).
AI_MAX_INCIDENT_COST_USD=0.50
# Per-workspace and global daily spend caps (USD), enforced before each call.
AI_DAILY_BUDGET_USD=25
AI_GLOBAL_DAILY_BUDGET_USD=100
# Fail closed on missing/invalid configuration (recommended: true).
AI_FAIL_CLOSED=true
# Provider pricing per million tokens, for deterministic cost estimation. Set
# these to the configured OpenAI model's per-million-token input/output prices so
# the budget caps above reflect real spend.
AI_PRICE_INPUT_PER_MTOK=15
AI_PRICE_OUTPUT_PER_MTOK=75
# Max retry attempts (job level) for retryable provider errors (timeout/5xx/rate-limit).
AI_MAX_RETRY_COUNT=2
# Optional: run triage inline right after queuing (single-process/demo only).
# Leave false in production so triage stays strictly asynchronous via the worker.
AI_TRIAGE_INLINE=false

# Email (Resend — required for transactional email in production)
EMAIL_PROVIDER=resend
MAIL_PROVIDER=resend
EMAIL_DOMAIN=
EMAIL_FROM=
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Base Real-time Ingestion Worker (realtime-worker process)
# ---------------------------------------------------------------------------
# The 300s polling worker continues to run as backup/backfill regardless of
# these settings. Set BASE_REALTIME_ENABLED=true and BASE_WS_RPC_URL to enable
# near-real-time (sub-30s) alert detection for Base wallet/RWA transfers.
#
# Defaults: disabled (BASE_REALTIME_ENABLED=false). Safe to leave unset in
# local dev; the polling worker handles backfill automatically.
#
BASE_REALTIME_ENABLED=false
BASE_REALTIME_PROVIDER=websocket
# WebSocket RPC URL for Base mainnet (required when BASE_REALTIME_ENABLED=true)
# Only the host is ever logged — never the full URL, path, or API key.
BASE_WS_RPC_URL=
#
# Provider failover ladder (order the worker tries endpoints in):
#   1. primary WSS       2. secondary WSS
#   3. secondary HTTP fast-tail (a DIFFERENT host)   4. stable RPC polling only
#
# BASE_WS_RPC_URL_PRIMARY is the explicit primary WSS (preferred over the legacy
# BASE_WS_RPC_URL / BASE_WS_RPC_URL_8453). BASE_WS_RPC_URL_SECONDARY is a SECOND
# WSS endpoint — ideally a DIFFERENT provider — the worker fails over to after the
# primary's circuit opens (repeated TLS / 1001 provider failures).
BASE_WS_RPC_URL_PRIMARY=
BASE_WS_RPC_URL_SECONDARY=
# HTTPS RPC endpoints for JSON-RPC calls (eth_blockNumber / eth_getLogs) and the
# HTTP fast-tail fallback. BASE_HTTP_RPC_URL_PRIMARY defaults to the legacy
# EVM_RPC_URL_8453 / BASE_EVM_RPC_URL / EVM_RPC_URL, then to the WS URL converted
# to https. BASE_HTTP_RPC_URL_SECONDARY is a SECOND HTTPS RPC on a DIFFERENT host.
#
# IMPORTANT: when the primary WSS fails with a TLS internal error the SAME host's
# HTTPS RPC fails the identical handshake, so the fast-tail is NOT run against it.
# Configure BASE_HTTP_RPC_URL_SECONDARY (a different provider) to keep a realtime
# fast-tail during a primary-host TLS outage; without it the worker fails closed to
# stable RPC polling only (provider_mode=stable_rpc_polling_fallback) — it never
# claims quicknode_http_fast_tail is active against the broken host.
BASE_HTTP_RPC_URL_PRIMARY=
BASE_HTTP_RPC_URL_SECONDARY=
# Webhook mode (alternative to websocket; requires BASE_WEBHOOK_SECRET)
BASE_WEBHOOK_SECRET=
# Confirmations to wait before processing a block (default 1; use 2 for extra safety)
BASE_REALTIME_CONFIRMATIONS=1
# Bounded gap backfill: max blocks scanned per cycle when the realtime cursor
# falls behind the chain head. Keeps a large gap from triggering one giant
# eth_getLogs scan on every new block (which burns QuickNode rate limits).
# Default 25, hard-capped at 25 (larger values are clamped down).
BASE_REALTIME_BACKFILL_CHUNK_SIZE=25
# Safe bootstrap: when true, if the realtime checkpoint is more than the gap
# threshold behind the chain head (or missing entirely), the worker skips the old
# historical gap and starts from the latest block minus confirmations instead of
# replaying it (logs realtime_start_at_latest_applied). A checkpoint that is only
# a few blocks behind is still resumed so no recent blocks are missed. Default
# false (resume from the persisted checkpoint and close gaps via bounded backfill).
BASE_REALTIME_START_AT_LATEST=false
# Rate limiter: max events persisted per minute across all monitored wallets.
# Default 1000 is very permissive; lower to protect DB during a high-volume event.
BASE_REALTIME_MAX_EVENTS_PER_MINUTE=1000
# When true (default), the polling worker continues to run as a fallback even
# when the realtime worker is active. Always recommended.
BASE_REALTIME_FALLBACK_TO_POLLING=true
# Provider rate-limit circuit breaker. When the provider rejects the WebSocket
# upgrade with HTTP 429 (a hard, provider-wide rate limit), the worker stops WSS
# reconnects for this cooldown window instead of reconnecting every 60-120s into
# the same limit. It publishes provider_rate_limited + a next-retry timestamp, and
# the 300s stable polling worker keeps detecting transfers. Realtime resumes once
# the cooldown clears. Default 900 seconds (15 minutes).
BASE_REALTIME_RATE_LIMIT_COOLDOWN_SECONDS=900
# Master gate for the HTTP fast-tail fallback. The fast-tail polls the SAME provider
# HTTP quota/host as the WSS, so on a rate limit it worsens the 429 and on a host TLS
# failure it just reproduces http_fast_tail_error. Default false: when disabled the
# provider-unhealthy fallback (WSS circuit open on TLS/provider failure) goes STRAIGHT
# to stable RPC polling only (provider_mode=stable_rpc_polling_fallback,
# realtime_scanning_active=False) and the fast-tail never starts. Only set true when a
# SEPARATE, healthy HTTP budget exists (e.g. BASE_HTTP_RPC_URL_SECONDARY on a different
# provider). Even when enabled, if the fast-tail's FIRST scan fails with a TLS/host
# error and no healthy HTTP host remains, the worker fails closed to
# stable_rpc_polling_fallback instead of looping http_fast_tail_error.
BASE_REALTIME_FAST_TAIL_ENABLED=false
# Fast-tail poll cadence over HTTPS RPC (never the WSS). Default 60s, floored at 5s.
# Logs quicknode_fast_tail_started / quicknode_fast_tail_scan_ok each cycle.
BASE_REALTIME_FAST_TAIL_INTERVAL_SECONDS=60
# Most-recent blocks scanned per fast-tail cycle (both eth_getLogs and the native
# ETH transaction scan). Bounds each poll so a stale checkpoint never scans a huge
# historical gap — stable polling closes deeper gaps. Default 10, hard-capped at 25.
BASE_REALTIME_FAST_TAIL_CHUNK_SIZE=10
# Maximum block lag the fast-tail will auto-catch-up. When the checkpoint is more than
# this many blocks behind head, the fast-tail logs realtime_fast_tail_lag_too_large and
# fast-forwards its cursor to a bounded window behind head instead of replaying the whole
# gap (which would burn provider quota — the 40k-block lag explosion). The skipped span
# is recovered via tx-hash import / bounded backfill and the 300s stable poller. Default
# 100; floored at BASE_REALTIME_FAST_TAIL_CHUNK_SIZE.
BASE_REALTIME_FAST_TAIL_MAX_CATCHUP_BLOCKS=100
# tx-hash debug mode (leave empty in normal operation). A comma/space-separated
# list of 0x transaction hashes. On startup the realtime worker fetches each via
# eth_getTransactionByHash and logs realtime_tx_debug (block/from/to/value/chain_id
# + per-target from_matches/to_matches and normalized addresses). If a listed tx's
# block is at/below the realtime checkpoint (so the forward head scan will never
# reach it), it logs realtime_tx_skipped_by_checkpoint and runs a bounded
# tx_block-2..tx_block+2 native scan (detected_by=realtime_websocket) WITHOUT
# advancing the forward checkpoint. Safe: read-only apart from that bounded,
# idempotent backfill; never sends a transaction. Default empty (disabled).
BASE_REALTIME_DEBUG_TX_HASHES=
