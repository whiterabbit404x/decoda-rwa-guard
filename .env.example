APP_MODE=local
SQLITE_PATH=.data/phase1.db
REDIS_ENABLED=false
# REDIS_URL is required in production (APP_ENV=production/prod/staging) for distributed rate
# limiting, session token revocation, and SSE alert streaming. Production startup will fail
# if REDIS_URL is missing or if Redis is not reachable at boot time.
# Leave blank for local/dev — in-memory fallback is used automatically (rate_limit_enterprise_ready=false).
REDIS_URL=
# REDIS_TEMPORARILY_DISABLED is REJECTED in production (APP_ENV=production/prod/staging).
# In local/dev only, setting this to 'true' allows running without Redis while showing
# degraded status. Never set this to 'true' in production — startup will fail with a clear error.
REDIS_TEMPORARILY_DISABLED=false

# Live EVM provider (required for live monitoring; leave empty in local dev)
EVM_RPC_URL=
EVM_CHAIN_ID=

# Per-chain RPC routing (multi-chain deployments). A target is routed to the RPC
# that serves the chain it is labeled with (targets.chain_network). Precedence:
#   1. EVM_RPC_URL_<chain_id>   e.g. EVM_RPC_URL_8453 (Base), EVM_RPC_URL_1 (Ethereum)
#   2. <CHAIN>_EVM_RPC_URL      e.g. BASE_EVM_RPC_URL, ETHEREUM_EVM_RPC_URL
#   3. EVM_RPC_URL / STAGING_EVM_RPC_URL global fallback
# The worker probes eth_chainId and FAILS CLOSED (skips, no telemetry) when the
# resolved endpoint does not serve the target's chain — so an Ethereum-labeled
# target is never scanned against a Base RPC. If you only configure a Base RPC,
# non-Base EVM targets are skipped/marked misconfigured rather than mis-reported.
EVM_RPC_URL_1=
EVM_RPC_URL_8453=
# Optional comma-separated per-chain failover endpoints, e.g. EVM_RPC_FAILOVER_URLS_8453=

# RPC pressure / rate-limit tuning. Defaults keep the provider from being
# rate-limited; raise the interval (or lower polling) if the provider quota is small.
#   EVM_POLLING_INTERVAL_SECONDS  worker poll cadence in seconds (default 60).
#                                 Legacy alias: MONITORING_WORKER_INTERVAL_SECONDS.
#   SYSTEM_HEALTH_RPC_TTL_SECONDS /system-health caches the Base RPC probe for this
#                                 many seconds so refreshes don't re-hit the RPC (default 60).
#   SYSTEM_HEALTH_RPC_TIMEOUT_SECONDS  bounded probe timeout for /system-health (default 8).
#   EVM_RPC_TIMEOUT_SECONDS / EVM_RPC_MAX_RETRIES / EVM_RPC_BACKOFF_SECONDS  worker
#                                 per-request timeout, retry count, and exponential backoff
#                                 (defaults 10 / 3 / 1). 429 responses honor Retry-After.
EVM_POLLING_INTERVAL_SECONDS=60

# Staging live EVM provider evidence (blocker 3).
# STAGING_EVM_RPC_URL is preferred over EVM_RPC_URL in staging proof generation.
# STAGING_EVM_CHAIN_ID is preferred over EVM_CHAIN_ID.
# STAGING_WORKER_ENABLED=true confirms the monitoring worker is active.
# Without these, provider_ready=false and live_evidence_ready=false (fail closed).
STAGING_EVM_RPC_URL=
STAGING_EVM_CHAIN_ID=1
STAGING_WORKER_ENABLED=true

# Billing (Paddle — required for paid launch; leave empty for pilot/no-billing mode)
BILLING_PROVIDER=paddle
PADDLE_ENVIRONMENT=production
PADDLE_API_KEY=
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
# Optional Paddle browser/redirect configuration
PADDLE_CLIENT_TOKEN=
PADDLE_SUCCESS_URL=
PADDLE_CANCEL_URL=
# Legacy Paddle flows only; prefer PADDLE_SELLER_ID when applicable
PADDLE_VENDOR_ID=
PADDLE_SELLER_ID=

# Email (Resend — required for transactional email in production)
EMAIL_PROVIDER=resend
MAIL_PROVIDER=resend
EMAIL_DOMAIN=
EMAIL_FROM=
RESEND_API_KEY=
