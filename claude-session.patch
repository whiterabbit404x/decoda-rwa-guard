+/**
+ * Source-level truthfulness tests for onboarding and dashboard empty states.
+ * Tests verify that the customer-facing UI guides users through the correct
+ * setup path and never shows misleading "healthy/all-clear" copy when monitoring
+ * is not yet configured.
+ */
+import { readFileSync } from 'node:fs';
+import path from 'node:path';
+import { expect, test } from '@playwright/test';
+
+function readSrc(relativePath: string): string {
+  return readFileSync(path.join(__dirname, '..', 'app', relativePath), 'utf-8');
+}
+
+const execSrc = () => readSrc('dashboard-executive-summary.tsx');
+const onboardingPanelSrc = () => readSrc('dashboard-onboarding-panel.tsx');
+const runtimeBannerSrc = () => readSrc('workspace-monitoring-mode-banner.tsx');
+const runtimePanelSrc = () => readSrc('runtime-summary-panel.tsx');
+
+// ── Onboarding panel ────────────────────────────────────────────────────────
+
+test('dashboard onboarding panel does not include "Live API reachable" as a customer step', () => {
+  const src = onboardingPanelSrc();
+  expect(src).not.toContain('Live API reachable');
+});
+
+test('dashboard onboarding panel shows 4 setup steps derived from onboarding progress', () => {
+  const src = onboardingPanelSrc();
+  expect(src).toContain('asset_added');
+  expect(src).toContain('target_created');
+  expect(src).toContain('monitoring_started');
+  expect(src).toContain('evidence_recorded');
+});
+
+test('dashboard onboarding panel marks current step with arrow indicator', () => {
=======
