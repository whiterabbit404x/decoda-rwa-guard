@@ -0,0 +1,222 @@
+/**
+ * Source-level truthfulness tests for onboarding and dashboard empty states.
+ * Tests verify that the customer-facing UI guides users through the correct
+ * setup path and never shows misleading "healthy/all-clear" copy when monitoring
+ * is not yet configured.
+ */
+import { readFileSync } from 'node:fs';
+import path from 'node:path';
+import { expect, test } from '@playwright/test';
+
+function readSrc(relativePath: string): string {
+  return readFileSync(path.join(__dirname, '..', 'app', relativePath), 'utf-8');
+}
+
+const execSrc = () => readSrc('dashboard-executive-summary.tsx');
+const onboardingPanelSrc = () => readSrc('dashboard-onboarding-panel.tsx');
+const runtimeBannerSrc = () => readSrc('workspace-monitoring-mode-banner.tsx');
+const runtimePanelSrc = () => readSrc('runtime-summary-panel.tsx');
+
+// ── Onboarding panel ────────────────────────────────────────────────────────
+
+test('dashboard onboarding panel does not include "Live API reachable" as a customer step', () => {
+  const src = onboardingPanelSrc();
+  expect(src).not.toContain('Live API reachable');
+});
+
+test('dashboard onboarding panel shows 4 setup steps derived from onboarding progress', () => {
+  const src = onboardingPanelSrc();
+  expect(src).toContain('asset_added');
+  expect(src).toContain('target_created');
+  expect(src).toContain('monitoring_started');
+  expect(src).toContain('evidence_recorded');
+});
+
+test('dashboard onboarding panel marks current step with arrow indicator', () => {
-    pilot._generate_export_artifact(connection, workspace_id='ws-1', export_id='exp-1')
+    meta = pilot._generate_export_artifact(connection, workspace_id='ws-1', export_id='exp-1')
     payload = json.loads(fake_storage.content.decode('utf-8'))
     row = payload['rows'][0]
-    assert sorted(row.keys()) == ['alerts.json', 'detection_metrics.json', 'evidence.json', 'incidents.json', 'summary.json']
-    assert row['summary.json']['incident_id'] == 'inc-1'
+    expected_keys = {
+        'alerts.json', 'detection_metrics.json', 'evidence.json', 'incidents.json',
+        'summary.json', 'detections.json', 'response_actions.json', 'audit_log.json',
+    }
+    assert set(row.keys()) == expected_keys
+    summary = row['summary.json']
+    assert summary['incident_id'] == 'inc-1'
+    assert 'export_status' in summary
+    assert 'evidence_source_type' in summary
+    assert 'missing_sections' in summary
+    assert 'chain_complete' in summary
     assert connection.storage_update_called is True
+    # artifact_meta propagated
+    assert meta.get('export_status') in {'complete', 'partial', 'incomplete'}
+    assert meta.get('evidence_source_type') in {'live', 'simulator', 'unavailable', 'missing', 'unknown'}
 
 
 def test_generate_export_artifact_report_template_includes_metadata(monkeypatch: pytest.MonkeyPatch) -> None:
