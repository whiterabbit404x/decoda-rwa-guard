# Staging environment configuration for Decoda RWA Guard
# Copy to .env.staging and fill in real values. Never commit real secrets.
#
# Required for staging_launch_ready=true:
STAGING_API_URL=
STAGING_APP_URL=
STAGING_DATABASE_URL=
STAGING_AUTH_TOKEN_SECRET=
STAGING_WORKER_ENABLED=true

# Required for blocker 3 live provider evidence proof.
# STAGING_EVM_RPC_URL must be a real Ethereum-compatible JSON-RPC endpoint.
# Do not commit real provider secrets.
# STAGING_EVM_RPC_URL is preferred over EVM_RPC_URL in staging mode.
# STAGING_EVM_CHAIN_ID is preferred over EVM_CHAIN_ID in staging mode.
# Without these, provider_ready=false and live_evidence_ready=false (fail closed).
STAGING_EVM_RPC_URL=
STAGING_EVM_CHAIN_ID=1

# Fallback EVM provider (used when STAGING_EVM_RPC_URL is not set):
EVM_RPC_URL=
EVM_CHAIN_ID=

# Multiple Base RPC providers with SAFE per-host failover (recommended for prod).
# Comma-separated, tried in order. A 429 from one provider benches ONLY that provider
# host; the next provider keeps serving so polling continues. Priority order:
# EVM_RPC_URLS → STAGING_EVM_RPC_URL → EVM_RPC_URL. Only the provider host is ever
# exposed in logs or the UI — never the full URL, path, or API key.
# Example: EVM_RPC_URLS=https://base-mainnet.g.alchemy.com/v2/KEY,https://base.quicknode.example/TOKEN
EVM_RPC_URLS=

# Per-chain RPC routing (multi-chain). Targets are routed to the RPC serving the
# chain they are labeled with. Precedence: EVM_RPC_URL_<chain_id> →
# <CHAIN>_EVM_RPC_URL → global STAGING_EVM_RPC_URL/EVM_RPC_URL. The worker probes
# eth_chainId and fails closed (skips, no telemetry) on a chain mismatch, so an
# Ethereum-labeled target is never scanned against a Base RPC.
EVM_RPC_URL_1=
EVM_RPC_URL_8453=


# REDIS_URL is required in staging (APP_ENV=staging) for distributed rate limiting, session
# token revocation, and SSE alert streaming. Staging startup will fail if REDIS_URL is missing
# or Redis is unreachable at boot time.
REDIS_URL=
# REDIS_TEMPORARILY_DISABLED is REJECTED in staging and production (APP_ENV=production/prod/staging).
# In local/dev only, setting this to 'true' allows running without Redis while showing degraded
# status. Never set this to 'true' in staging or production — startup will fail with a clear error.
REDIS_TEMPORARILY_DISABLED=false

# Required for broad paid SaaS readiness (billing + email):
BILLING_PROVIDER=paddle
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_DOMAIN=

# Billing credentials — Paddle (recommended):
PADDLE_ENVIRONMENT=production
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=

# Billing credentials — Stripe (alternative):
# BILLING_PROVIDER=stripe
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# Email credentials (example for SendGrid):
# SENDGRID_API_KEY=SG....

# Validation behaviour:
# Set to true only to allow missing staging config to pass in pilot-mode validation.
# Must NOT be set in production broad-SaaS validation.
# STAGING_EVIDENCE_ALLOW_MISSING=false
