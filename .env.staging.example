# Staging environment configuration for Decoda RWA Guard
# Copy to .env.staging and fill in real values. Never commit real secrets.
# On Railway: set these as environment variables in the service dashboard.
#
# Required for staging_launch_ready=true:
STAGING_API_URL=
STAGING_APP_URL=
STAGING_DATABASE_URL=
STAGING_AUTH_TOKEN_SECRET=
STAGING_WORKER_ENABLED=true

# Required for blocker 3 live provider evidence proof.
# STAGING_EVM_RPC_URL must be a real Ethereum-compatible JSON-RPC endpoint.
# Do not commit real provider secrets.
# STAGING_EVM_RPC_URL is preferred over EVM_RPC_URL in staging mode.
# STAGING_EVM_CHAIN_ID is preferred over EVM_CHAIN_ID in staging mode.
# Without these, provider_ready=false and live_evidence_ready=false (fail closed).
# In strict/staging proof mode, missing RPC URL exits non-zero — not a code failure.
STAGING_EVM_RPC_URL=
STAGING_EVM_CHAIN_ID=1

# Aliases accepted as fallback when STAGING_* vars are not set:
EVM_RPC_URL=
EVM_CHAIN_ID=
WORKER_ENABLED=true

# Required for broad paid SaaS readiness (billing + email):
BILLING_PROVIDER=
BILLING_WEBHOOK_SECRET=
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_DOMAIN=

# Billing credentials (example for Stripe):
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# Email credentials (example for SendGrid):
# SENDGRID_API_KEY=SG....

# Validation behaviour:
# Set to true only to allow missing staging config to pass in pilot-mode validation.
# Must NOT be set in production broad-SaaS validation.
# STAGING_EVIDENCE_ALLOW_MISSING=false

# ============================================================================
# Railway deployment variables
# Set all of the above in your Railway service environment dashboard.
# Railway-specific variable names (if different from above):
#
# STAGING_API_URL       — public URL of the deployed API service
# STAGING_APP_URL       — public URL of the deployed web app
# STAGING_DATABASE_URL  — Railway Postgres DATABASE_URL (auto-injected on link)
# STAGING_AUTH_TOKEN_SECRET — JWT signing secret (generate with: openssl rand -hex 32)
# STAGING_WORKER_ENABLED    — set to "true" to confirm worker service is running
# STAGING_EVM_RPC_URL   — Infura/Alchemy/etc JSON-RPC endpoint (use Railway secret)
# STAGING_EVM_CHAIN_ID  — 1 for Ethereum mainnet, 11155111 for Sepolia testnet
#
# Aliases (accepted when STAGING_* form not set):
# EVM_RPC_URL          — fallback for STAGING_EVM_RPC_URL
# EVM_CHAIN_ID         — fallback for STAGING_EVM_CHAIN_ID
# WORKER_ENABLED       — fallback for STAGING_WORKER_ENABLED
# ============================================================================
