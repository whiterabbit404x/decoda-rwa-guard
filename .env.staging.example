# Staging environment configuration for Decoda RWA Guard
# Copy to .env.staging and fill in real values. Never commit real secrets.
#
# Required for staging_launch_ready=true:
STAGING_API_URL=
STAGING_APP_URL=
STAGING_DATABASE_URL=
STAGING_AUTH_TOKEN_SECRET=
STAGING_WORKER_ENABLED=true

# Required for live EVM provider:
EVM_RPC_URL=
EVM_CHAIN_ID=

# Required for broad paid SaaS readiness (billing + email):
BILLING_PROVIDER=
BILLING_WEBHOOK_SECRET=
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_DOMAIN=

# Optional staging overrides:
STAGING_EVM_RPC_URL=
STAGING_EVM_CHAIN_ID=
STAGING_BASE_URL=
STAGING_EVIDENCE_EMAIL=
STAGING_EVIDENCE_PASSWORD=

# Billing credentials (example for Stripe):
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# Email credentials (example for SendGrid):
# SENDGRID_API_KEY=SG....

# Validation behaviour:
# Set to true only to allow missing staging config to pass in pilot-mode validation.
# Must NOT be set in production broad-SaaS validation.
# STAGING_EVIDENCE_ALLOW_MISSING=false
