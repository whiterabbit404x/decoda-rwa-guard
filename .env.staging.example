# Staging environment configuration for Decoda RWA Guard
# Copy to .env.staging and fill in real values. Never commit real secrets.
#
# Required for staging_launch_ready=true:
STAGING_API_URL=
STAGING_APP_URL=
STAGING_DATABASE_URL=
STAGING_AUTH_TOKEN_SECRET=
STAGING_WORKER_ENABLED=true

# Required for blocker 3 live provider evidence proof.
# STAGING_EVM_RPC_URL must be a real Ethereum-compatible JSON-RPC endpoint.
# Do not commit real provider secrets.
# STAGING_EVM_RPC_URL is preferred over EVM_RPC_URL in staging mode.
# STAGING_EVM_CHAIN_ID is preferred over EVM_CHAIN_ID in staging mode.
# Without these, provider_ready=false and live_evidence_ready=false (fail closed).
STAGING_EVM_RPC_URL=
STAGING_EVM_CHAIN_ID=1

# Fallback EVM provider (used when STAGING_EVM_RPC_URL is not set):
EVM_RPC_URL=
EVM_CHAIN_ID=


# Distributed rate limiting. Prefer REDIS_URL. Temporary staging/single-instance only:
REDIS_URL=
REDIS_TEMPORARILY_DISABLED=false
# Setting the temporary-disable flag true keeps startup available but leaves
# rate_limit_enterprise_ready=false and enterprise_ready=false.

# Required for broad paid SaaS readiness (billing + email):
BILLING_PROVIDER=paddle
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_DOMAIN=

# Billing credentials — Paddle (recommended):
PADDLE_ENVIRONMENT=production
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=

# Billing credentials — Stripe (alternative):
# BILLING_PROVIDER=stripe
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# Email credentials (example for SendGrid):
# SENDGRID_API_KEY=SG....

# Validation behaviour:
# Set to true only to allow missing staging config to pass in pilot-mode validation.
# Must NOT be set in production broad-SaaS validation.
# STAGING_EVIDENCE_ALLOW_MISSING=false
