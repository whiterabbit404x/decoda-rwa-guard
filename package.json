{
  "name": "phase1-treasury-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:clean": "npm ci",
    "build:web": "NEXT_PUBLIC_LIVE_MODE_ENABLED=false API_URL=https://api.example.com npm run build --workspace apps/web",
    "validate:no-billing-launch": "make validate-no-billing-launch",
    "validate:paid-ga": "make validate-paid-ga",
    "proof:no-billing-launch": "make proof-no-billing-launch",
    "proof:staging-live": "python scripts/run_staging_live_evidence_proof.py",
    "test:backend:feature2-smoke": "python -m pytest services/api/tests/test_feature2_smoke.py -q",
    "test:frontend:feature2-smoke": "playwright test apps/web/tests/feature2-smoke.spec.ts",
    "smoke:feature2": "python scripts/smoke_feature2.py",
    "test:backend:feature3-smoke": "python -m pytest services/api/tests/test_feature3_smoke.py -q",
    "test:frontend:feature3-smoke": "playwright test apps/web/tests/feature3-smoke.spec.ts",
    "smoke:feature3": "python scripts/smoke_feature3.py",
    "test:backend:feature4-smoke": "python -m pytest services/api/tests/test_feature4_smoke.py -q",
    "test:frontend:feature4-smoke": "playwright test apps/web/tests/feature4-smoke.spec.ts",
    "smoke:feature4": "python scripts/smoke_feature4.py",
    "evidence:staging": "python scripts/staging/run_evidence_flow.py",
    "test:frontend:staging-evidence": "playwright test apps/web/tests/staging-evidence-flow.spec.ts",
    "test": "node scripts/run-web-tests.mjs",
    "build": "npm run build --workspace apps/web"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "playwright": "1.55.1",
    "postcss": ">=8.5.10"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "next": {
      "postcss": ">=8.5.10"
    }
  }
}
