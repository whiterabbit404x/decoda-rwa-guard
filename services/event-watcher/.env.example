APP_MODE=local
SERVICE_NAME=event-watcher
PORT=8005
SQLITE_PATH=.data/phase1.db
REDIS_ENABLED=false
MONITORING_INGESTION_MODE=live
LIVE_MONITORING_ENABLED=true
EVM_RPC_URL=
# Optional: multiple Base RPC providers with per-host failover (comma-separated,
# tried in order; a 429 benches only that provider host). Takes priority over
# EVM_RPC_URL. Only the provider host is ever logged — never the full URL or key.
EVM_RPC_URLS=
EVM_WS_URL=
EVENT_WATCHER_CHECKPOINT_PATH=/tmp/event-watcher-checkpoint.json
