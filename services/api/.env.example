# Primary for feature dev: local Postgres
APP_MODE=local
LIVE_MODE_ENABLED=true
PORT=8000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/decoda_rwa_guard_dev

# Demo-only UI fallback: SQLite
# APP_MODE=demo
# LIVE_MODE_ENABLED=false
# DATABASE_URL=sqlite:////tmp/decoda-rwa-guard-demo.db

# Staging/prod verification: Neon/hosted Postgres
# DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
AUTH_TOKEN_SECRET=replace-with-long-random-secret
RUN_MIGRATIONS_ON_STARTUP=false
MIGRATION_LOCK_WAIT_SECONDS=45
MIGRATION_LOCK_RETRY_INTERVAL_SECONDS=1
MIGRATION_RETRY_ATTEMPTS=3
MIGRATION_RETRY_BACKOFF_SECONDS=1
APP_ENV=development
APP_PUBLIC_URL=http://localhost:3000
AUTH_EXPOSE_DEBUG_TOKENS=false
MFA_ISSUER=Decoda RWA Guard
# Local development may use console; production must use resend.
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@decoda.app
EMAIL_BRAND_NAME=Decoda RWA Guard
EMAIL_RESEND_API_KEY=
# Optional distributed auth rate limiting. The API falls back to an in-memory limiter.
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
BACKGROUND_JOBS_MODE=inline
# CORS origin allowlist. Production example:
# CORS_ALLOWED_ORIGINS=https://rwa.decodasecurity.com,https://staging.rwa.decodasecurity.com,http://localhost:3000,http://127.0.0.1:3000
# Local development example:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional legacy alias if CORS_ALLOWED_ORIGINS is not set.
ALLOWED_ORIGINS=
# Enable only for intentional cross-origin cookie auth flows.
CORS_ALLOW_CREDENTIALS=false
RISK_ENGINE_URL=http://localhost:8001
THREAT_ENGINE_URL=http://localhost:8002
MONITORING_INGESTION_MODE=hybrid
LIVE_MONITORING_ENABLED=true
LIVE_MONITORING_CHAINS=ethereum
EVM_RPC_URL=
# Staging-specific EVM provider override (preferred over EVM_RPC_URL in staging proof)
STAGING_EVM_RPC_URL=
EVM_CHAIN_ID=
# Staging chain ID override
STAGING_EVM_CHAIN_ID=
# Set to true in staging to confirm the monitoring worker is active
STAGING_WORKER_ENABLED=
EVM_WS_URL=
EVM_CONFIRMATIONS_REQUIRED=3
EVM_BLOCK_LOOKBACK=25
EVM_BLOCK_SCAN_CHUNK_SIZE=25
COMPLIANCE_SERVICE_URL=http://localhost:8004
RECONCILIATION_SERVICE_URL=http://localhost:8005
RISK_ENGINE_TIMEOUT_SECONDS=1.5
THREAT_ENGINE_TIMEOUT_SECONDS=1.5
COMPLIANCE_SERVICE_TIMEOUT_SECONDS=1.5
RECONCILIATION_SERVICE_TIMEOUT_SECONDS=1.5
# Billing readiness
STRICT_PRODUCTION_BILLING=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Secret encryption (required for staging/production)
SECRET_ENCRYPTION_KEY=
SECRET_ENCRYPTION_KEY_ID=env-default

# Durable export storage (required: s3 in staging/production)
EXPORT_STORAGE_BACKEND=local
EXPORTS_DIR=/tmp/decoda-exports
EXPORT_S3_BUCKET=
EXPORT_S3_REGION=us-east-1
EXPORT_S3_PREFIX=decoda-exports
EXPORT_S3_ENDPOINT=
# Set true to surface S3 Object Lock / WORM status in export metadata
EXPORT_S3_OBJECT_LOCK_ENABLED=
# Emergency override: allow local storage in production (unsafe, logs a WARNING)
EXPORT_ALLOW_LOCAL_IN_PRODUCTION=false

# Tamper-evident export signing (required in staging/production)
# Use a long random secret, minimum 32 bytes. Rotate by changing key_id.
EXPORT_SIGNING_SECRET=
# Alias accepted if EXPORT_SIGNING_SECRET is not set
EVIDENCE_SIGNING_SECRET=
# Identifier for the active signing key (used for key rotation)
EXPORT_SIGNING_KEY_ID=env-default

# Request body size limits (bytes; defaults shown)
MAX_REQUEST_BODY_BYTES=10485760
MAX_UPLOAD_BODY_BYTES=52428800
MAX_INGEST_BODY_BYTES=20971520

# Debug endpoints (PRODUCTION: must be absent or false; dev: set true to enable /debug/*)
# ENABLE_DEBUG_ENDPOINTS=false

# Demo fallback dashboards (set false in production to enforce live-data-only responses)
# ENABLE_DEMO_FALLBACKS=false

# Proof/test script credentials — NEVER hardcode in source; set via environment
# PROOF_PASSWORD=<set-for-local-proof-scripts-only>
# PADDLE_WEBHOOK_SECRET=<paddle-webhook-signing-secret>

# Production cryptographic key rollout:
# - compatibility (default): existing env keys keep the service available while readiness
#   reports managed_key_provider=false and startup logs a migration warning.
# - strict: env keys are rejected; enable only after all managed secret IDs are provisioned.
# Supported managed production provider: aws_secrets_manager
MANAGED_KEY_PROVIDER=env
MANAGED_KEY_ENFORCEMENT=compatibility
AUTH_TOKEN_KEY_SECRET_ID=
AUTH_TOKEN_KEY_VERSION=
AUTH_TOKEN_KEY_ENCODING=utf8
SECRET_ENCRYPTION_KEY_SECRET_ID=
SECRET_ENCRYPTION_KEY_VERSION=
SECRET_ENCRYPTION_KEY_ENCODING=base64
EVIDENCE_SIGNING_KEY_SECRET_ID=
EVIDENCE_SIGNING_KEY_VERSION=
EVIDENCE_SIGNING_KEY_ENCODING=utf8

# Durable data-retention worker
RETENTION_WORKER_NAME=retention-worker
RETENTION_WORKER_INTERVAL_SECONDS=300
RETENTION_WORKER_BATCH_SIZE=25
RETENTION_WORKER_STALE_AFTER_SECONDS=900
